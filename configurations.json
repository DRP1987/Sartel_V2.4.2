{
  "configurations": [
    {
      "name": "LWE.FMS.2020 (Engine-Upper and LMB override status)",
      "info_pdf": "config/docs/FMS_Liebherr.pdf",
      "signals": [
        {
          "name": "Engine On_RPM<200",
          "can_id": "0x18F00401",
          "match_type": "range",
          "protocol": "j1939",
          "byte_index": 4,
          "min_value": "0x06",
          "max_value": "0xFF"
        },
        {
          "name": "Crane-Upper running",
          "can_id": "0x18FFE001",
          "protocol": "j1939",
          "match_type": "bit",
          "byte_index": 0,
          "bit_index": 0,
          "bit_value": 1
        },
        {
          "name": "LMB override",
          "can_id": "0x18FFE001",
          "protocol": "j1939",
          "match_type": "bit",
          "byte_index": 2,
          "bit_index": 1,
          "bit_value": 1
        }
      ],
      "pgn_channels": [
        {
          "label": "Engine RPM",
          "pgn": "0xF004",
          "bytes": [3, 4],
          "byte_order": "little_endian",
          "scale": 0.125,
          "offset": 0.0,
          "unit": "rpm",
          "format": "{:.2f}"
        },
        {
          "label": "Engine Oil pressure",
          "pgn": "0xFEEF",
          "bytes": [3],
          "byte_order": "little_endian",
          "scale": 0.04,
          "offset": 0,
          "unit": "Bar",
          "format": "{:.2f}"
        },
        {
          "label": "Engine Coolant temp",
          "pgn": "0xFEEE",
          "bytes": [0],
          "byte_order": "little_endian",
          "scale": 1,
          "offset": -40,
          "unit": "°C",
          "format": "{:.2f}"
        },
        {
          "label": "Engine Oil temp",
          "pgn": "0xFEEE",
          "bytes": [2,3],
          "byte_order": "little_endian",
          "scale": 0.03125,
          "offset": -273,
          "unit": "°C",
          "format": "{:.2f}"
        },
        {
          "label": "Engine Fuel temp",
          "pgn": "0xFEEE",
          "bytes": [1],
          "byte_order": "little_endian",
          "scale": 1,
          "offset": -40,
          "unit": "°C",
          "format": "{:.2f}"
        },
        {
          "label": "Engine Coolant level",
          "pgn": "0xFEEF",
          "bytes": [7],
          "byte_order": "little_endian",
          "scale": 0.4,
          "offset": 0,
          "unit": "%",
          "format": "{:.2f}"
        },
        {
          "label": "Engine Total hours",
          "pgn": "0xFEE5",
          "bytes": [0,1,2,3],
          "byte_order": "little_endian",
          "scale": 0.05,
          "offset": 0,
          "unit": "h",
          "format": "{:.2f}"
        },
        {
          "label": "Engine Total HR fuel used",
          "pgn": "0xFD09",
          "bytes": [4,5,6,7],
          "byte_order": "little_endian",
          "scale": 0.001,
          "offset": 0,
          "unit": "l",
          "format": "{:.2f}"
        },
        {
          "label": "Engine Total fuel used",
          "pgn": "0xFEE9",
          "bytes": [4,5,6,7],
          "byte_order": "little_endian",
          "scale": 0.5,
          "offset": 0,
          "unit": "l",
          "format": "{:.2f}"
        },
        {
          "label": "Engine Fuel Rate",
          "pgn": "0xFEF2",
          "bytes": [0,1],
          "byte_order": "little_endian",
          "scale": 0.05,
          "offset": 0,
          "unit": "l/h",
          "format": "{:.2f}"
        }
      ],
      "dm1_enabled": true 
    },
